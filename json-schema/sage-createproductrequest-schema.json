{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/CreateProductRequest",
  "title": "CreateProductRequest",
  "type": "object",
  "properties": {
    "product": {
      "type": "object",
      "required": [
        "description"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "item_code": {
          "type": "string"
        },
        "sales_prices": {
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/PriceInput"
          }
        },
        "sales_ledger_account_id": {
          "type": "string"
        },
        "tax_rate_id": {
          "type": "string"
        }
      }
    }
  }
}